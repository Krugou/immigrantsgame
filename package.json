{
  "name": "frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "analyze:bundle": "ANALYZE=true next build",
    "build": "next build",
    "check:i18n": "tsx ./scripts/check-translations.ts",
    "clean": "rimraf .next node_modules",
    "dev": "cross-env PORT=3100 next dev --experimental-https",
    "format": "prettier --write .",
    "generate:icons": "tsx ./scripts/generate-icons.ts",
    "lint": "eslint --quiet",
    "lint:quiet": "eslint --quiet",
    "prepare": "husky install",
    "lint-staged": {
      "*.txt": [
        "git rm --cached",
        "rm -f"
      ],
      "*.{ts,tsx,js,jsx}": [
        "eslint --fix --quiet",
        "prettier --write"
      ],
      "*.{json,css,md}": [
        "prettier --write"
      ]
    },
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --quiet --reporter=list",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "framer-motion": "^12.34.3",
    "i18next": "^25.8.13",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-i18next": "^16.5.4",
    "react-virtuoso": "^4.18.1"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.6",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "tailwindcss": "^4.2.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "vitest": "^4.0.18"
  }
}
